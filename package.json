{
  "name": "tgame",
  "version": "0.1.0",
  "description": "Competitive Linux sysadmin terminal game with Elo ranking and shared-filesystem chaos rooms",
  "type": "module",
  "main": "server/index.js",
  "bin": {
    "tgame": "bin/tgame.js"
  },
  "scripts": {
